# Admin dashboard password (required for /admin)
# Copy to .env.local and restart `npm run dev` after changing.
ADMIN_PASSWORD=your-secure-password-here

# Google Apps Script web app URL for RSVP submissions (saved to Google Sheets)
# Set in Vercel env vars for production. Either variable works on the server.
GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXX/exec
NEXT_PUBLIC_GOOGLE_SCRIPT_URL=https://script.google.com/macros/s/XXXXXXXXXXXXXXXX/exec
